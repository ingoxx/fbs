@charset "UTF-8";
.box {
  display: flex;
  flex-direction: column;
  height: 100%;
  padding-bottom: 220rpx;
  /* send 的高度（或比它稍大） */
  box-sizing: border-box;
  min-height: 100vh;
  background: #1f2937;
}

.box .addr {
  height: 130rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  background: #675094;
}

.box .addr .addr-content {
  color: #ffffff;
  font-size: 27rpx;
}

.box .open-time {
  height: 60rpx;
  line-height: 60rpx;
  padding-left: 15rpx;
  background: #2b3748;
  color: #ffffff;
  font-size: 24rpx;
}

.box .chat {
  display: flex;
  flex: 1;
  flex-direction: column;
  background: #1f2937;
}

.box .chat .chat-content {
  color: #ffffff;
  font-size: 27rpx;
  background: #374151;
  margin: 33rpx 0;
  border-radius: 10rpx;
  max-width: 300rpx;
  margin-left: 50rpx;
  padding: 20rpx;
}

.box .chat .chat-content .user, .box .chat .chat-content .time {
  color: #a5a5a5;
  font-size: 25rpx;
  padding: 14rpx 0;
}

.box .chat .chat-content.left {
  align-self: flex-start;
}

.box .chat .chat-content.right {
  align-self: flex-end;
  margin-right: 50rpx;
}

.box .chat .chat-content.friend {
  background: #374151;
}

.box .chat .chat-content.my {
  background: #ff976a;
  color: #ffffff;
}

.box .send {
  display: flex;
  justify-items: center;
  align-items: center;
  height: 190rpx;
  position: fixed;
  padding: 30rpx;
  bottom: 0rpx;
  width: 100%;
  background: #2b3748;
  box-sizing: border-box;
}

.box .send .content {
  flex: 1;
  /* 关键！占据剩余空间 */
  height: 60rpx;
  line-height: 60rpx;
  border: 1rpx #d2d2d2 solid;
  border-radius: 9rpx;
  font-size: 25rpx;
  color: #ffffff;
  padding: 0 20rpx;
  /* 给输入框留点内边距 */
  margin-bottom: 38rpx;
}

.box .send .content .send-input {
  padding-top: 7rpx;
}

.box .send .submit {
  height: 70rpx;
  line-height: 70rpx;
  padding-left: 15rpx;
  color: #fff;
  margin-bottom: 38rpx;
}

.van-icon-c {
  position: relative !important;
  right: 9rpx !important;
  top: 3rpx !important;
}
